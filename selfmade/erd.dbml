// 카카오톡 선물하기 CRM 분석 프로젝트 ERD
// dbdiagram.io 에 붙여넣기: https://dbdiagram.io/d
// 작성일: 2026-04-03

Table users {
  user_id             varchar   [pk, note: "U00001 형식"]
  gender              varchar   [note: "M / F"]
  age_group           varchar   [note: "10대 / 20대 / 30대 / 40대 / 50대+"]
  device_type         varchar   [note: "ios / android"]
  acquisition_channel varchar   [note: "organic / ad / gift_received / search"]
  first_action_type   varchar   [note: "sent / received"]
  referral_generation int       [note: "0=오가닉, 1=1세대 바이럴, 2=2세대 ..."]
  referred_by_user_id varchar   [null, note: "FK → users.user_id (self-ref). 오가닉이면 null"]

  Note: '''
  정규화 원칙: joined_at / first_sent_at / total_sent_count 등 파생값은 제외.
  orders + gift_receipts 집계 뷰로 계산.
  인구통계: F 62% / 30대 38% / gift_received 유입 40% (리서치 기반)
  '''
}

Table orders {
  order_id             varchar    [pk, note: "ORD000001 형식"]
  sender_user_id       varchar    [not null, ref: > users.user_id]
  occasion_category    varchar    [not null, note: "special / daily"]
  occasion_subcategory varchar    [not null, note: "seasonal / personal / social / self"]
  gift_occasion        varchar    [not null, note: "pepero_day / birthday / self_gift 등 21개 값"]
  entry_route          varchar    [note: "friend_list / chat_room / gift_tab_direct / campaign_link / search_direct"]
  discovery_method     varchar    [note: "ranking / curation / search / category_browse / campaign_banner"]
  product_id           varchar    [note: "PRD0001 형식"]
  brand_name           varchar
  category_l1          varchar    [note: "food / beauty / health / fashion / lifestyle / voucher"]
  category_l2          varchar    [note: "cafe_voucher / skincare / red_ginseng 등"]
  unit_price_krw       int        [note: "할인 전 단가 (원화)"]
  total_amount_krw     int        [note: "실제 결제금액. RFM M 기준값"]
  discount_amount_krw  int        [default: 0]
  order_status         varchar    [note: "pending_accepted / accepted / expired / refunded"]
  is_code_gift         boolean    [default: false, note: "코드선물 여부 (링크/코드 전달 → 발신자 미노출)"]
  created_at           timestamp  [note: "주문 생성 시각. RFM R 기준값"]
  updated_at           timestamp

  Note: '''
  발신자·수신자 분리 구조: sender_user_id(구매자) ↔ gift_receipts.receiver_user_id(수령자)
  self_gift: sender_user_id == gift_receipts.receiver_user_id + gift_occasion = self_gift
  '''
}

Table gift_receipts {
  receipt_id       varchar    [pk, note: "RCP000001 형식"]
  order_id         varchar    [not null, ref: - orders.order_id, note: "1:1 관계"]
  receiver_user_id varchar    [not null, ref: > users.user_id]
  accepted_at      timestamp  [null, note: "수락 시각. null이면 미수락(pending/expired)"]
  expires_at       timestamp  [not null, note: "orders.created_at + 30일"]
  receipt_status   varchar    [note: "pending / accepted / expired / option_changed"]

  Note: '''
  sent_at 제거: orders.created_at과 동일 → 중복 컬럼 제거 (정규화)
  Viral Loop 분석: 동일 user_id가 receiver → sender로 전환되는 패턴 추적
  '''
}

Table campaigns {
  campaign_id          varchar  [pk, note: "CMP001 형식"]
  campaign_name        varchar  [note: "2024_pepero_d7_A 등 날짜+이벤트+세그먼트+variant"]
  channel              varchar  [note: "friendtalk / brand_message / in_app_message"]
  target_segment       varchar  [note: "champions / at_risk / new_customers 등 RFM 세그먼트"]
  occasion_category    varchar  [note: "special / daily"]
  occasion_subcategory varchar  [note: "seasonal / personal / social / self"]
  gift_occasion        varchar  [note: "연계 시즌값. 시즌 무관이면 none"]
  message_type         varchar  [note: "curation / ranking / discount / seasonal (소재 전략)"]
  message_variation    varchar  [note: "A / B (A/B 테스트 버전)"]
  send_date            date
  target_user_count    int

  Note: '''
  A/B 설계: curation(A) CTR 6%/CVR 15% vs ranking(B) CTR 18%/CVR 4%
  채널 2체계 (2025 카카오 개편): 알림톡(정보성) / 브랜드메시지(광고성, 친구톡 흡수)
  '''
}

Table campaign_logs {
  log_id               varchar    [pk, note: "LOG0000001 형식"]
  campaign_id          varchar    [not null, ref: > campaigns.campaign_id]
  user_id              varchar    [not null, ref: > users.user_id]
  message_type         varchar    [note: "campaigns.message_type과 동일. 조인 편의용 비정규화"]
  message_variation_id varchar    [note: "A / B"]
  event_type           varchar    [note: "send / open / click / block / purchase"]
  occurred_at          timestamp  [note: "이벤트 발생 시각. send→open→click→purchase 순서"]
  device_type          varchar    [note: "ios / android"]
  platform             varchar    [default: "kakao"]

  Note: '''
  1 유저 × 1 캠페인 = 최대 5개 이벤트 (send→open→click→purchase or block)
  A/B 분석 쿼리: CTR = COUNT(click)/COUNT(send), CVR = COUNT(purchase)/COUNT(click)
  '''
}

// ── 자기 참조 관계 (Viral referral) ──────────────────────────────────────
Ref: users.referred_by_user_id > users.user_id
